# ============================================================
# VARIÁVEIS DE AMBIENTE — COPIE ESTE ARQUIVO PARA .env
# ============================================================

# Banco de Dados PostgreSQL
DB_URL=

# Chave secreta do Flask — OBRIGATÓRIO EM PRODUÇÃO
# Gere uma chave segura com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Credenciais do container PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Ambiente (development | production)
FLASK_ENV=production
