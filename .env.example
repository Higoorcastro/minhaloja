# ============================================================
# VARIÁVEIS DE AMBIENTE — COPIE ESTE ARQUIVO PARA .env
# ============================================================

# Banco de Dados PostgreSQL
DB_URL=postgresql://postgres:SENHA@db:5432/minhaloja_db

# Credenciais do container PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SENHA_AQUI
POSTGRES_DB=minhaloja_db

# Chave secreta do Flask — OBRIGATÓRIO EM PRODUÇÃO
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Ativar cookie seguro (true apenas se tiver HTTPS configurado no Nginx)
SESSION_COOKIE_SECURE=false

# Gunicorn — workers e timeout (opcional, padrão: 2 workers, 120s timeout)
# Fórmula recomendada para workers: (2 * nº de CPUs) + 1
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
